import matplotlib.pyplot as plt
import numpy as np

# ==========================================
# PARAMETRI CONDIVISI
# ==========================================
x = np.linspace(0, 15, 1000)  # Esteso a 15 per vedere meglio la convergenza
t_0 = 5                        # Il punto di attivazione (dopo 5 x)
y_0 = 0                        # Valore iniziale prima dell'attivazione

# ==========================================
# FINESTRA 1: Scalino vs Sigmoide Esponenziale
# ==========================================
plt.figure(num="Grafico 1: Scalino vs Sigmoide Esponenziale", figsize=(8, 5))

# Parametri specifici per la sigmoide (curva di carica)
C_0 = 1.0   # Valore asintotico finale
T = 1.5     # Costante di tempo (regola la velocitŕ di salita)
t_i = 0     # Ritardo aggiuntivo rispetto a t_0 (impostato a 0)

# Scalino: 0 prima di t_0, 1 dopo
y_scalino = np.where(x >= t_0, 1.0, 0.0)

# Sigmoide secondo la formula: y_0 + (C_0 - y_0) * (1 - e^(-(x - (t_i + t_0)) / T))
# Attiva solo per x >= (t_i + t_0), altrimenti rimane a y_0
t_attivazione_sig = t_i + t_0
y_sigmoide = np.where(
    x >= t_attivazione_sig,
    y_0 + (C_0 - y_0) * (1 - np.exp(-(x - t_attivazione_sig) / T)),
    y_0
)

# Disegno Grafico 1
plt.plot(x, y_scalino, color='black', linewidth=2.5, label='Scalino (Soglia x=5)')
plt.plot(x, y_sigmoide, color='deepskyblue', linewidth=2, linestyle='--', label='Sigmoide Esponenziale')

plt.title('Funzione a Scalino vs Sigmoide Esponenziale', fontsize=12, fontweight='bold')
plt.xlabel('X')
plt.ylabel('Y')
plt.ylim(-0.1, 1.3)
plt.grid(True, linestyle=':', alpha=0.6)
plt.legend(loc='lower right')


# ==========================================
# FINESTRA 2: Coseno Modificato
# ==========================================
plt.figure(num="Grafico 2: Coseno Spostato", figsize=(8, 5))

# Parametri specifici per il coseno
A = 1.5      # Ampiezza dell'oscillazione
w = 2.0      # Frequenza angolare (omega)

# Coseno secondo la formula: y_0 + A * cos(w * (x - t_0))
# Attivo solo per x >= t_0, altrimenti rimane a y_0
y_coseno = np.where(
    x >= t_0,
    y_0 + A * np.cos(w * (x - t_0)),
    y_0
)

# Disegno Grafico 2
plt.plot(x, y_coseno, color='forestgreen', linewidth=2, label=r'$y_0 + A \cdot \cos(w(x-t_0))$')
plt.axvline(x=t_0, color='red', linestyle=':', label='Inizio segnale ($t_0=5$)')

plt.title('Funzione Coseno attiva dopo x = 5', fontsize=12, fontweight='bold')
plt.xlabel('X')
plt.ylabel('Y')
plt.ylim(y_0 - A - 0.5, y_0 + A + 0.5)  # Limiti dinamici in base all'ampiezza
plt.grid(True, linestyle=':', alpha=0.6)
plt.legend(loc='upper left')


# ==========================================
# MOSTRA I GRAFICI
# ==========================================
plt.show()
